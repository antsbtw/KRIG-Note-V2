{
  "id": "krig.basic.rect",
  "category": "basic",
  "name": "Rectangle",
  "renderer": "parametric",
  "viewBox": { "w": 100, "h": 100 },
  "aspect": "variable",
  "path": [
    { "cmd": "M", "x": 0,   "y": 0   },
    { "cmd": "L", "x": "w", "y": 0   },
    { "cmd": "L", "x": "w", "y": "h" },
    { "cmd": "L", "x": 0,   "y": "h" },
    { "cmd": "Z" }
  ],
  "magnets": [
    { "id": "N", "x": 0.5, "y": 0   },
    { "id": "E", "x": 1,   "y": 0.5 },
    { "id": "S", "x": 0.5, "y": 1   },
    { "id": "W", "x": 0,   "y": 0.5 }
  ],
  "textBox": { "l": 0, "t": 0, "r": "w", "b": "h" },
  "default_style": {
    "fill":  { "type": "solid", "color": "#4A90E2", "transparency": 0 },
    "line":  { "type": "solid", "color": "#2E5C8A", "width": 1.5, "dashType": "solid" },
    "arrow": { "begin": "none", "end": "none" }
  },
  "source": "builtin"
}

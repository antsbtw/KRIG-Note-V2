{
  "id": "krig.line.curved",
  "category": "line",
  "name": "Curved Connector",
  "renderer": "parametric",
  "viewBox": { "w": 100, "h": 100 },
  "aspect": "variable",
  "guides": [
    { "name": "x1", "op": "*/", "args": ["w", 1, 3] },
    { "name": "x2", "op": "*/", "args": ["w", 2, 3] }
  ],
  "path": [
    { "cmd": "M", "x": 0, "y": 0 },
    { "cmd": "C", "x1": "x1", "y1": 0, "x2": "x2", "y2": "h", "x": "w", "y": "h" }
  ],
  "magnets": [
    { "id": "START", "x": 0, "y": 0 },
    { "id": "END",   "x": 1, "y": 1 }
  ],
  "default_style": {
    "fill":  { "type": "none" },
    "line":  { "type": "solid", "color": "#2E5C8A", "width": 1.5, "dashType": "solid" },
    "arrow": { "begin": "none", "end": "none" }
  },
  "source": "builtin"
}

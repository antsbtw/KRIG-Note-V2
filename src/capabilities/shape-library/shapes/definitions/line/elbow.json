{
  "id": "krig.line.elbow",
  "category": "line",
  "name": "Elbow Connector",
  "renderer": "parametric",
  "viewBox": { "w": 100, "h": 100 },
  "aspect": "variable",
  "params": {
    "midRatio": {
      "type": "number",
      "default": 0.5,
      "min": 0.1,
      "max": 0.9,
      "label": "Bend position",
      "unit": "ratio"
    }
  },
  "guides": [
    { "name": "mx", "op": "*/", "args": ["w", "midRatio", 1] }
  ],
  "path": [
    { "cmd": "M", "x": 0,    "y": 0   },
    { "cmd": "L", "x": "mx", "y": 0   },
    { "cmd": "L", "x": "mx", "y": "h" },
    { "cmd": "L", "x": "w",  "y": "h" }
  ],
  "magnets": [
    { "id": "START", "x": 0, "y": 0 },
    { "id": "END",   "x": 1, "y": 1 }
  ],
  "default_style": {
    "fill":  { "type": "none" },
    "line":  { "type": "solid", "color": "#2E5C8A", "width": 1.5, "dashType": "solid" },
    "arrow": { "begin": "none", "end": "none" }
  },
  "source": "builtin"
}
